# YouTube Data API v3
# Google Cloud Console → APIs & Services → Credentials → Create API key
YOUTUBE_DATA_API_KEY=

# Twitter/X API v2 — Basic tier (last 7 days, hyped terms only)
# developer.twitter.com → Projects & Apps → Keys and Tokens
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Reddit OAuth app (script type)
# reddit.com/prefs/apps → create app → type: script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mini-rag/1.0 by <your_reddit_username>

# Apify — TikTok actor: clockworks/tiktok-scraper (GdWCkxBtKWOsKjdch)
# apify.com → Settings → Integrations → API token
# Cost: ~$0.005/result ($5/1000). 10 results × 12 terms = ~$0.60/run
APIFY_API_TOKEN=

# OpenAI — ingest_deep_research.py term converter (gpt-4.1-nano)
# platform.openai.com → API Keys
OPENAI_API_KEY=

# Anthropic — M3 classifier
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Google Trends — no key needed (uses pytrends, free)
